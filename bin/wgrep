#!/usr/bin/env bash
# WAQQAS_TOOLSET
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [ -f "$SCRIPT_DIR/../lib/common.sh" ]; then
  WAQ_HOME="$(cd "$SCRIPT_DIR/.." && pwd)"
elif [ -f "${WAQQAS_TOOLSET_HOME:-$HOME/.waqqas-toolset}/lib/common.sh" ]; then
  WAQ_HOME="${WAQQAS_TOOLSET_HOME:-$HOME/.waqqas-toolset}"
else
  echo "[!] Could not locate Waqqas Toolset library. Reinstall with install.sh." >&2
  exit 1
fi
# shellcheck source=/dev/null
. "$WAQ_HOME/lib/common.sh"

usage() {
  cat <<'EOF'
Usage:
  wgrep <pattern> [path]

Search across the current project if present, otherwise the workspace.
EOF
}

pattern="${1:-}"
path="${2:-}"

[ -n "$pattern" ] || { usage; exit 1; }

if [ -z "$path" ]; then
  if root="$(waq_project_root 2>/dev/null)"; then
    path="$root"
  else
    path="$(waq_workspace)"
  fi
fi

if waq_have rg; then
  rg -n --hidden --glob '!*.zip' --glob '!*.tar.gz' "$pattern" "$path"
else
  grep -RIn --exclude='*.zip' --exclude='*.tar.gz' "$pattern" "$path"
fi
