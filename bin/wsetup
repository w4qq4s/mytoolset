#!/usr/bin/env bash
# WAQQAS_TOOLSET
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [ -f "$SCRIPT_DIR/../lib/common.sh" ]; then
  WAQ_HOME="$(cd "$SCRIPT_DIR/.." && pwd)"
elif [ -f "${WAQQAS_TOOLSET_HOME:-$HOME/.waqqas-toolset}/lib/common.sh" ]; then
  WAQ_HOME="${WAQQAS_TOOLSET_HOME:-$HOME/.waqqas-toolset}"
else
  echo "[!] Could not locate Waqqas Toolset library. Reinstall with install.sh." >&2
  exit 1
fi
# shellcheck source=/dev/null
. "$WAQ_HOME/lib/common.sh"

usage() {
  cat <<'EOF'
Usage:
  wsetup
EOF
}

if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
  usage
  exit 0
fi

echo "Waqqas Toolset"
echo "Version: $(waq_version)"
echo "Home: $(waq_tool_home)"
echo "Repo: $(waq_repo)"
echo

echo "Commands:"
bin_dir="$HOME/.local/bin"
for cmd in wsetup wupdate ctfinit boxprep tmuxbox wnote wgrep lootindex scanwrap portpeek webprobe dnspeek httphead myip netcheck flagscan extractall hashid jwtpeek htbsave; do
  if command -v "$cmd" >/dev/null 2>&1; then
    printf '  [ok] %s -> %s\n' "$cmd" "$(command -v "$cmd")"
  elif [ -x "$bin_dir/$cmd" ]; then
    printf '  [installed-not-in-path] %s -> %s\n' "$cmd" "$bin_dir/$cmd"
  else
    printf '  [missing] %s\n' "$cmd"
  fi
done
echo

echo "Dependencies:"
for dep in bash curl jq tmux unzip file dig ip openssl tar; do
  if command -v "$dep" >/dev/null 2>&1; then
    printf '  [ok] %s\n' "$dep"
  else
    printf '  [missing] %s\n' "$dep"
  fi
done
echo

if root="$(waq_project_root 2>/dev/null)"; then
  echo "Current project: $root"
else
  echo "Current project: none detected"
fi

echo "Workspace: $(waq_workspace)"
