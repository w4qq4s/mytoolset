#!/usr/bin/env bash
# WAQQAS_TOOLSET
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [ -f "$SCRIPT_DIR/../lib/common.sh" ]; then
  WAQ_HOME="$(cd "$SCRIPT_DIR/.." && pwd)"
elif [ -f "${WAQQAS_TOOLSET_HOME:-$HOME/.waqqas-toolset}/lib/common.sh" ]; then
  WAQ_HOME="${WAQQAS_TOOLSET_HOME:-$HOME/.waqqas-toolset}"
else
  echo "[!] Could not locate Waqqas Toolset library. Reinstall with install.sh." >&2
  exit 1
fi
# shellcheck source=/dev/null
. "$WAQ_HOME/lib/common.sh"

usage() {
  cat <<'EOF'
Usage:
  webprobe <url>

Fetch headers, title, and common metadata quickly.
EOF
}

url="${1:-}"
[ -n "$url" ] || { usage; exit 1; }

waq_require curl

tmp="$(mktemp)"
trap 'rm -f "$tmp" "$tmp.headers" "$tmp.body"' EXIT

curl -ksSL --max-time 15 -D "$tmp.headers" "$url" -o "$tmp.body"

echo "Headers:"
sed 's/
$//' "$tmp.headers"
echo

title="$(grep -oim1 '<title[^>]*>.*</title>' "$tmp.body" | sed -E 's/<[^>]+>//g' || true)"
server="$(grep -im1 '^server:' "$tmp.headers" | cut -d' ' -f2- | tr -d '
' || true)"
powered="$(grep -im1 '^x-powered-by:' "$tmp.headers" | cut -d' ' -f2- | tr -d '
' || true)"
generator="$(grep -oim1 '<meta[^>]+name=["'"'"']generator["'"'"'][^>]+content=["'"'"'][^"'"'"']+' "$tmp.body" | sed -E 's/.*content=["'"'"']([^"'"'"']+).*/\1/' || true)"

echo "Summary:"
[ -n "$title" ] && echo "  Title: $title"
[ -n "$server" ] && echo "  Server: $server"
[ -n "$powered" ] && echo "  X-Powered-By: $powered"
[ -n "$generator" ] && echo "  Generator: $generator"

echo
echo "Security headers:"
for h in "content-security-policy" "strict-transport-security" "x-frame-options" "x-content-type-options" "referrer-policy"; do
  if grep -iq "^$h:" "$tmp.headers"; then
    grep -i "^$h:" "$tmp.headers" | sed 's/\r$//' | sed 's/^/  /'
  fi
done

echo
echo "Interesting paths:"
for p in /robots.txt /.well-known/security.txt /sitemap.xml; do
  code="$(curl -ksS -o /dev/null -w '%{http_code}' --max-time 8 "${url%/}$p" || true)"
  printf '  %-28s %s\n' "$p" "$code"
done
