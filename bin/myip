#!/usr/bin/env bash
# WAQQAS_TOOLSET
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [ -f "$SCRIPT_DIR/../lib/common.sh" ]; then
  WAQ_HOME="$(cd "$SCRIPT_DIR/.." && pwd)"
elif [ -f "${WAQQAS_TOOLSET_HOME:-$HOME/.waqqas-toolset}/lib/common.sh" ]; then
  WAQ_HOME="${WAQQAS_TOOLSET_HOME:-$HOME/.waqqas-toolset}"
else
  echo "[!] Could not locate Waqqas Toolset library. Reinstall with install.sh." >&2
  exit 1
fi
# shellcheck source=/dev/null
. "$WAQ_HOME/lib/common.sh"

usage() {
  cat <<'EOF'
Usage:
  myip
EOF
}

if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
  usage
  exit 0
fi

waq_require ip
waq_require curl

echo "Interfaces:"
ip -brief addr | sed 's/^/  /'
echo

echo "Default route:"
ip route | grep '^default' | sed 's/^/  /' || true
echo

echo "Public IP:"
curl -fsSL https://api.ipify.org
echo
