#!/usr/bin/env bash
# WAQQAS_TOOLSET
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [ -f "$SCRIPT_DIR/../lib/common.sh" ]; then
  WAQ_HOME="$(cd "$SCRIPT_DIR/.." && pwd)"
elif [ -f "${WAQQAS_TOOLSET_HOME:-$HOME/.waqqas-toolset}/lib/common.sh" ]; then
  WAQ_HOME="${WAQQAS_TOOLSET_HOME:-$HOME/.waqqas-toolset}"
else
  echo "[!] Could not locate Waqqas Toolset library. Reinstall with install.sh." >&2
  exit 1
fi
# shellcheck source=/dev/null
. "$WAQ_HOME/lib/common.sh"

usage() {
  cat <<'EOF'
Usage:
  netcheck
EOF
}

if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
  usage
  exit 0
fi

waq_require ip

echo "resolv.conf:"
(cat /etc/resolv.conf || true) | sed 's/^/  /'
echo

echo "Routing:"
ip route | sed 's/^/  /'
echo

gw="$(ip route | awk '/default/ {print $3; exit}')"
if [ -n "$gw" ]; then
  if ping -c 2 -W 2 "$gw" >/dev/null 2>&1; then
    echo "Gateway ping: ok ($gw)"
  else
    echo "Gateway ping: fail ($gw)"
  fi
else
  echo "Gateway ping: no default gateway"
fi

if getent hosts example.com >/dev/null 2>&1; then
  echo "DNS lookup: ok"
else
  echo "DNS lookup: fail"
fi

if ping -c 2 -W 2 1.1.1.1 >/dev/null 2>&1; then
  echo "Internet reachability: ok"
else
  echo "Internet reachability: fail"
fi

if curl -fsSL --max-time 6 https://example.com >/dev/null 2>&1; then
  echo "HTTPS: ok"
else
  echo "HTTPS: fail"
fi
