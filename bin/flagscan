#!/usr/bin/env bash
# WAQQAS_TOOLSET
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [ -f "$SCRIPT_DIR/../lib/common.sh" ]; then
  WAQ_HOME="$(cd "$SCRIPT_DIR/.." && pwd)"
elif [ -f "${WAQQAS_TOOLSET_HOME:-$HOME/.waqqas-toolset}/lib/common.sh" ]; then
  WAQ_HOME="${WAQQAS_TOOLSET_HOME:-$HOME/.waqqas-toolset}"
else
  echo "[!] Could not locate Waqqas Toolset library. Reinstall with install.sh." >&2
  exit 1
fi
# shellcheck source=/dev/null
. "$WAQ_HOME/lib/common.sh"

usage() {
  cat <<'EOF'
Usage:
  flagscan [path]

Search recursively for common flag formats.
EOF
}

path="${1:-$PWD}"
pattern='HTB\{[^}]+\}|THM\{[^}]+\}|flag\{[^}]+\}|FLAG\{[^}]+\}|CTF\{[^}]+\}'

if waq_have rg; then
  rg -n -I -e "$pattern" "$path"
else
  grep -RInE "$pattern" "$path"
fi
