#!/usr/bin/env bash
# WAQQAS_TOOLSET
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [ -f "$SCRIPT_DIR/../lib/common.sh" ]; then
  WAQ_HOME="$(cd "$SCRIPT_DIR/.." && pwd)"
elif [ -f "${WAQQAS_TOOLSET_HOME:-$HOME/.waqqas-toolset}/lib/common.sh" ]; then
  WAQ_HOME="${WAQQAS_TOOLSET_HOME:-$HOME/.waqqas-toolset}"
else
  echo "[!] Could not locate Waqqas Toolset library. Reinstall with install.sh." >&2
  exit 1
fi
# shellcheck source=/dev/null
. "$WAQ_HOME/lib/common.sh"

usage() {
  cat <<'EOF'
Usage:
  tmuxbox [session-name]

Create or attach to a tmux session for the current project.
EOF
}

waq_require tmux

if ! root="$(waq_project_root 2>/dev/null)"; then
  waq_die "Run tmuxbox inside a project created by ctfinit"
fi

session="${1:-waq_$(basename "$root")}"

if ! tmux has-session -t "$session" 2>/dev/null; then
  tmux new-session -d -s "$session" -c "$root"
  tmux rename-window -t "$session:0" "shell"
  tmux new-window -t "$session" -n "recon" -c "$root/recon"
  tmux new-window -t "$session" -n "notes" -c "$root/notes"
  tmux new-window -t "$session" -n "web" -c "$root/web"
  tmux send-keys -t "$session:notes" "sed -n '1,120p' notes.md" C-m
fi

tmux attach -t "$session"
